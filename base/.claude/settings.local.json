{
  "permissions": {
    "allow": [
      "Bash(python -m orchestrator init:*)",
      "Bash(python -m orchestrator plan:*)",
      "Bash(python -m orchestrator add-task:*)",
      "Bash(python -m orchestrator dispatch:*)",
      "Bash(python -m orchestrator status:*)",
      "Bash(python -m orchestrator merge:*)",
      "Bash(python -m orchestrator sessions:*)",
      "Bash(python -m orchestrator clean:*)"
    ]
  },
  "env": {
    "ORCH_AGENT_CMD": "codex",
    "ORCH_APPROVAL_MODE": "full-auto",
    "ORCH_USE_WORKTREE": "true",
    "ORCH_BASE_BRANCH": "main",
    "ORCH_AGENT_TIMEOUT": "600"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/suggest-compact.sh"
          }
        ],
        "description": "전략적 compact 제안 — 논리적 전환점에서 /compact 권유"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/git-push-reminder.sh"
          }
        ],
        "description": "git push 전 리뷰 리마인더"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/lessons-reminder.sh",
            "timeout": 5
          }
        ],
        "description": "세션 중 교훈 기록 리마인더"
      }
    ]
  }
}
